{
  "name": "eslint-config-envylabs",
  "version": "1.5.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "prepack": "npm run clean && npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "javascript",
    "typescript",
    "ecmascript",
    "eslint",
    "eslintconfig",
    "lint",
    "config",
    "prettier",
    "envylabs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/envylabs/eslint-config-envylabs"
  },
  "author": "Envy Labs (envylabs.com)",
  "license": "MIT",
  "description": "Shared ESLint configuration for Envy Labs projects",
  "dependencies": {
    "@eslint/js": "^9 || ^10",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-import-x": "^4.15.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.4.1",
    "typescript-eslint": "^8.33.1"
  },
  "peerDependencies": {
    "eslint": "^9 || ^10"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "eslint": "^10.2.0",
    "jiti": "^2.4.2",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
